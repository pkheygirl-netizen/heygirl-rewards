# Copy to `.env` and fill in real values. `.env` is gitignored — never commit secrets.
# In production these are set as Render environment variables, not from a file.

# --- Shopify ---
SHOPIFY_API_KEY=your_shopify_client_id
SHOPIFY_API_SECRET=your_shopify_client_secret
SHOPIFY_APP_URL=https://your-app.onrender.com
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOP_DOMAIN=your-store.myshopify.com
SCOPES=read_customers,write_customers,read_orders,read_discounts,write_discounts,read_script_tags,write_script_tags,read_products,write_products

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Redis (BullMQ queues/workers) ---
REDIS_URL=redis://default:password@host:6379

# --- Email (SMTP) ---
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM="HeyGirl Rewards <noreply@your-domain.com>"

# --- Runtime ---
# WORKER=1 runs the background worker process instead of the web server.
# NODE_ENV is set by the platform.
